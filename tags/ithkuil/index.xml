 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td style="text-align: center"&gt;Stem 1&lt;/td&gt;
 &lt;td style="text-align: center"&gt;a&lt;/td&gt;
 &lt;td style="text-align: center"&gt;ä&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: center"&gt;Stem 2&lt;/td&gt;
 &lt;td style="text-align: center"&gt;e&lt;/td&gt;
