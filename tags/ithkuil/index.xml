 &lt;th style="text-align: center"&gt;PRC&lt;/th&gt;
 &lt;th style="text-align: center"&gt;CPT&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td style="text-align: center"&gt;Stem 1&lt;/td&gt;
 &lt;td style="text-align: center"&gt;ai&lt;/td&gt;
 &lt;td style="text-align: center"&gt;au&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: center"&gt;Stem 2&lt;/td&gt;
 &lt;td style="text-align: center"&gt;ei&lt;/td&gt;
 &lt;td style="text-align: center"&gt;eu&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: center"&gt;Stem 3&lt;/td&gt;
 &lt;td style="text-align: center"&gt;ui&lt;/td&gt;
 &lt;td style="text-align: center"&gt;iu&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: center"&gt;Stem 0&lt;/td&gt;
 &lt;td style="text-align: center"&gt;oi&lt;/td&gt;
 &lt;td style="text-align: center"&gt;ou&lt;/td&gt;
