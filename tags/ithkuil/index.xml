 &lt;td style="text-align: center"&gt;ou&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;
&lt;ul&gt;
&lt;li&gt;当 C&lt;sub&gt;A&lt;/sub&gt; 为 Perspective N 时，Slot I C&lt;sub&gt;C&lt;/sub&gt; 为 &lt;code&gt;-w-&lt;/code&gt;，此时 Slot II 规则如下：&lt;/li&gt;
&lt;/ul&gt;
&lt;table&gt;
 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th style="text-align: center"&gt;&lt;/th&gt;
 &lt;th style="text-align: center"&gt;PRC&lt;/th&gt;
 &lt;th style="text-align: center"&gt;CPT&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td style="text-align: center"&gt;Stem 1&lt;/td&gt;
 &lt;td style="text-align: center"&gt;ia&lt;/td&gt;
 &lt;td style="text-align: center"&gt;ie&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: center"&gt;Stem 2&lt;/td&gt;
 &lt;td style="text-align: center"&gt;io&lt;/td&gt;
 &lt;td style="text-align: center"&gt;iö&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: center"&gt;Stem 3&lt;/td&gt;
